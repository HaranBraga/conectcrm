# ──────────────────────────────────────────────
# Banco de dados PostgreSQL (obrigatório)
# ──────────────────────────────────────────────
DATABASE_URL="postgresql://USUARIO:SENHA@HOST:5432/base"

# ──────────────────────────────────────────────
# Evolution API / WhatsApp (obrigatório para envios)
# ──────────────────────────────────────────────
EVOLUTION_API_URL="https://sua-evolution.dominio.com"
EVOLUTION_API_KEY="sua-api-key"
EVOLUTION_INSTANCE="nome-da-instancia"

# ──────────────────────────────────────────────
# Auth (OBRIGATÓRIO em produção)
# ──────────────────────────────────────────────
# Gere com: openssl rand -hex 32
# Em production, o app NÃO sobe se essa estiver vazia ou < 32 chars.
AUTH_SECRET="cole-aqui-uma-string-aleatoria-de-pelo-menos-32-chars"

# Admin inicial criado no primeiro boot, se não houver nenhum usuário.
# Pode trocar a senha em /perfil ou em Configurações > Usuários.
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="trocar-na-primeira-vez"

# ──────────────────────────────────────────────
# Webhook (recomendado em produção)
# ──────────────────────────────────────────────
# Se setado, o /api/webhook exige header `x-webhook-token: <valor>`.
# Configure o mesmo token no dispatch da Evolution. Sem WEBHOOK_TOKEN,
# o endpoint fica aberto (compatível com setups antigos).
# WEBHOOK_TOKEN="cole-aqui-um-token-secreto"

# ──────────────────────────────────────────────
# NUNCA suba o arquivo .env no git
# Adicione essas variáveis diretamente no Easypanel
# ──────────────────────────────────────────────
